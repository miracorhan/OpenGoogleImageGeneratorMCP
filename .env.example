# Google Cloud Project ID (Required)
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id

# Google Cloud region (Optional, default: us-central1)
GOOGLE_CLOUD_LOCATION=us-central1

# Directory where generated images/videos will be saved (Optional, default: ./outputs)
DEFAULT_OUTPUT_DIR=./outputs

# --- Google GenAI SDK backend (Optional) ---
# Controls which backend is used for live_generate, embed, analyze_video, generate_speech tools.
# Default is "vertex_ai" (uses ADC/OAuth + your GOOGLE_CLOUD_PROJECT).

# Option A — Cloud API Key (recommended if you have GCP credits):
#   Enables newer models (gemini-3.5-flash, gemini-3.1-pro, etc.) using your existing
#   GCP project billing. No separate AI Studio account needed.
#   Create at: Google Cloud Console → APIs & Services → Credentials → Create API Key
#
# GOOGLE_CLOUD_API_KEY=AIza...

# Option B — Gemini API key (AI Studio):
#   Uses Google AI Studio billing (separate from GCP). Free tier available.
#   Get key at: https://aistudio.google.com/apikey
#
# GOOGLE_GENAI_BACKEND=gemini_api
# GOOGLE_GENAI_API_KEY=AIza...

# --- Advanced Authentication (Optional) ---

# Direct OAuth 2.0 access token (bypasses ADC)
# GOOGLE_ACCESS_TOKEN=ya29.a0AfB_by...

# Service account to impersonate
# IMPERSONATE_SERVICE_ACCOUNT=your-service-account@your-project.iam.gserviceaccount.com
